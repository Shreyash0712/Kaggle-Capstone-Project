# LLM API Keys (At least one is required)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
ACTIVE_LLM_PROVIDER=gemini # or groq

# Tooling
TAVILY_API_KEY=your_tavily_api_key_here

# Image Storage
CLOUDINARY_URL=your_api_key_here

# Database (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=aletheox
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Neon Variables
PGHOST=your_host_here
PGDATABASE='neondb'
PGUSER='neondb_owner'
PGPASSWORD=your_password_here
PGSSLMODE='require'
PGCHANNELBINDING='require'

# Authentication Config
SECRET_KEY=generate_a_random_secret_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth Config
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth Config
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP Config for Email Verification
# You can use a free tier from SendGrid, Mailgun, or simply use an App Password from your Gmail account.
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
FRONTEND_URL=http://localhost:5173

# Backend Config
PORT=7860
ENVIRONMENT=development
